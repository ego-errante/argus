# Argus environment — copy to .env and fill in.
# See docs/PLAN.md → "Open items before Day 1".

ARGUS_NETWORK=mainnet            # mainnet (real path + Lifecycle Log) | devnet (chaos sandbox)

# SolInfra-provided endpoints (claim the bounty credits).
# NOTE: SolInfra issues per-scope keys. RPC_HTTP_URL/RPC_WS_URL need an
# RPC-scoped key; YELLOWSTONE_X_TOKEN is a separate gRPC-scoped key. They differ.
RPC_HTTP_URL=
RPC_WS_URL=
YELLOWSTONE_GRPC_URL=
YELLOWSTONE_X_TOKEN=

# Jito (mainnet — Jito only lands bundles on mainnet, see ADR 0002)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
# Optional Jito x-jito-auth UUID for rate-limit / forwarding headroom (leave blank
# for the unauthenticated public tier).
JITO_AUTH_UUID=
# Optional authed bundle relay that speaks Jito-compatible sendBundle over plain
# JSON-RPC — gives forwarding headroom past the public tier's "globally rate
# limited" wall. For SolInfra: the RPC endpoint with an RPC-scoped key, e.g.
# https://fra.rpc.solinfra.dev/sol?api_key=YOUR_RPC_KEY  (sendBundle = 60 CU PAYG).
JITO_BUNDLE_RELAY_URL=

# Helius Sender — PRIMARY submission path (ADR 0007). Keyless; dual-routes through
# staked validators + Jito, landing where the public Jito tier won't. Set
# HELIUS_SWQOS_ONLY=true for the cheaper staked-only lane (5k vs 200k lamport tip).
HELIUS_SENDER_URL=https://sender.helius-rpc.com/fast
HELIUS_SWQOS_ONLY=false

# Dedicated low-balance mainnet keypair (gitignored; never commit)
KEYPAIR_PATH=./secrets/keypair.json

# AI Agent (TypeScript service) — model access via OpenRouter (ADR 0006)
AGENT_URL=http://localhost:8787/decide
AGENT_PORT=8787
OPENROUTER_API_KEY=
AGENT_MODEL=anthropic/claude-sonnet-4.6          # primary model (OpenRouter slug)
AGENT_MODEL_FALLBACKS=                           # optional, comma-separated, tried in order
AGENT_REASONING_MAX_TOKENS=2048                  # reasoning-token budget for the Reasoning Trace

# Lifecycle store (SQLite source of truth)
ARGUS_DB_PATH=logs/argus.db

RUST_LOG=info
