# Argus environment — copy to .env and fill in.
# See docs/PLAN.md → "Open items before Day 1".

ARGUS_NETWORK=mainnet            # mainnet (real path + Lifecycle Log) | devnet (chaos sandbox)

# SolInfra-provided endpoints (claim the bounty credits).
# NOTE: SolInfra issues per-scope keys. RPC_HTTP_URL/RPC_WS_URL need an
# RPC-scoped key; YELLOWSTONE_X_TOKEN is a separate gRPC-scoped key. They differ.
RPC_HTTP_URL=
RPC_WS_URL=
YELLOWSTONE_GRPC_URL=
YELLOWSTONE_X_TOKEN=

# Jito (mainnet — Jito only lands bundles on mainnet, see ADR 0002)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Jito SearcherService gRPC endpoint for getNextScheduledLeader (NoAuth, ADR 0008).
# Must be a REGIONAL host — the bare mainnet host does not serve the searcher gRPC.
JITO_SEARCHER_GRPC_URL=https://frankfurt.mainnet.block-engine.jito.wtf
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
# Tip Floor percentile for the Base Tip: one of 25/50/75/95/99 (default 75,
# landing-biased). No hardcoded tip — ADR 0005.
JITO_TIP_PERCENTILE=75
# Optional Jito x-jito-auth UUID for rate-limit / forwarding headroom (leave blank
# for the unauthenticated public tier).
JITO_AUTH_UUID=
# Optional authed bundle relay that speaks Jito-compatible sendBundle over plain
# JSON-RPC — gives forwarding headroom past the public tier's "globally rate
# limited" wall. For SolInfra: the RPC endpoint with an RPC-scoped key, e.g.
# https://fra.rpc.solinfra.dev/sol?api_key=YOUR_RPC_KEY  (sendBundle = 60 CU PAYG).
JITO_BUNDLE_RELAY_URL=

# Helius Sender — PRIMARY submission path (ADR 0007). Keyless; dual-routes through
# staked validators + Jito, landing where the public Jito tier won't. Set
# HELIUS_SWQOS_ONLY=true for the cheaper staked-only lane (5k vs 200k lamport tip).
HELIUS_SENDER_URL=https://sender.helius-rpc.com/fast
HELIUS_SWQOS_ONLY=false
# Sender per-route minimum tips + mandated compute budget. Defaults are Sender's
# documented values; override only if Sender changes its minimums.
SENDER_DUAL_MIN_TIP_LAMPORTS=200000
SENDER_SWQOS_MIN_TIP_LAMPORTS=5000
SENDER_COMPUTE_UNIT_LIMIT=20000
SENDER_PRIORITY_FEE_MICROLAMPORTS=100000

# Streaming resilience (ADR 0009): bounded channel between the gRPC receive task
# and the consumer (sheds + counts surplus on a full channel) + reconnect ceiling.
ARGUS_STREAM_CHANNEL_CAP=1024
ARGUS_STREAM_MAX_RECONNECTS=10

# Deterministic fault injection (ADR 0010/0012). Leave UNSET for a clean run. One of the
# bounded faults: expired_blockhash | compute_exceeded | bundle_failure; or a foreign-program
# fault (ADR 0012): foreign_memo | foreign_token | foreign_whirlpool. The faulted attempt is
# classified via preflight simulation, a Remedy is chosen by the Policy, and (unless Abort)
# attempt 2 resubmits.
# Usage: ARGUS_INJECT=expired_blockhash ARGUS_LIFECYCLE=1 cargo run -p argus-core
ARGUS_INJECT=

# The Run orchestrator (ARGUS_RUN=1): number of clean Payloads after the injections
# (default 7 → 6 injections + 7 clean = 13 Payloads). Optional tuning knob.
ARGUS_RUN_CLEAN_COUNT=7

# Dedicated low-balance mainnet keypair (gitignored; never commit)
KEYPAIR_PATH=./secrets/keypair.json

# AI Agent (TypeScript service) — model access via OpenRouter (ADR 0006)
AGENT_URL=http://localhost:8787/decide
AGENT_PORT=8787
OPENROUTER_API_KEY=
AGENT_MODEL=anthropic/claude-sonnet-4.6          # primary model (OpenRouter slug)
AGENT_MODEL_FALLBACKS=                           # optional, comma-separated, tried in order
AGENT_REASONING_MAX_TOKENS=2048                  # reasoning-token budget for the Reasoning Trace
# Decision source for injected Failures: `agent` = the AI Agent over HTTP; anything else
# (default) = the local default policy stand-in. Set `agent` for the scored Run (ADR 0006/0010).
ARGUS_POLICY=local
ARGUS_AGENT_TIMEOUT_SECS=45                       # bound on the Agent decide round-trip (reasoning is slow)

# Lifecycle store (SQLite source of truth)
ARGUS_DB_PATH=logs/argus.db

RUST_LOG=info
